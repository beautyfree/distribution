# Open Distribution Registry — source of node data.
# Fetched at build time via raw.githubusercontent.com.
REGISTRY_REPO=beautyfree/distribution-registry
REGISTRY_BRANCH=main

# Optional: point at a local clone of the registry during development.
# When set, the StaticRegistrySource reads JSON from this path instead of
# hitting GitHub. Example: /Users/you/code/distribution-registry
# REGISTRY_LOCAL_PATH=

# LLM access. Use OPENROUTER_API_KEY (preferred) OR OPENAI_API_KEY.
# Both chat (draft generation) and embeddings (semantic search) work via OpenRouter now.
# Without either, reader runs in topical/stub mode — still usable.
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# OPENAI_API_KEY=sk-...
